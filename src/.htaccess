<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /boardgametracker/
  
  # Si la petición es para la API, no hacer nada
  RewriteRule ^api/ - [L]

  # Si el archivo o carpeta existe, servirlo
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo lo demás al index.html
  RewriteRule ^ index.html [L]
</IfModule>
